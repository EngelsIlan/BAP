pipeline {
    agent any

    environment {
        IMAGE_NAME = "cra-python-test:${BUILD_NUMBER}"
        APP_CONTAINER_NAME = "cra-python-test"
        APP_PORT = "9091"
        APP_INTERNAL_PORT = "8000"
        BAP_REPO = "https://github.com/EngelsIlan/BAP.git"
    }

    stages {
        stage('Checkout') {
            steps {
                git url: 'https://github.com/EngelsIlan/BAP.git',
                    branch: 'main'
                sh 'ls -a'
            }
        }

        stage('Build Container Image') {
            steps {
                sh '''
                    echo "BUILDING PYTHON DOCKER IMAGE"
                    docker build -f Docker/Dockerfile.python.CLEAN -t "${IMAGE_NAME}" .
                    docker images | grep cra-python-test
                '''
            }
        }

        stage('Parallel Security Checks') {
            parallel {
                stage('SBOM Flow') {
                    stages {
                        stage('Generate SBOM') {
                            steps {
                                sh '''
                                    apt-get update -q
                                    apt-get install -y jq python3
                                    curl -sSfL https://raw.githubusercontent.com/anchore/syft/main/install.sh | sh -s -- -b .
                                    ./syft scan dir:BAP -o cyclonedx-json > sbom.cdx.json
                                '''
                            }
                        }

                        stage('Validate & Archive SBOM') {
                            steps {
                                sh '''
                                    jq empty sbom.cdx.json
                                    COUNT=$(jq '.components | length' sbom.cdx.json)
                                    if [ "$COUNT" -eq 0 ]; then
                                      echo "ERROR: empty SBOM"
                                      exit 1
                                    fi
                                '''
                                archiveArtifacts artifacts: 'sbom.cdx.json', fingerprint: true
                            }
                        }
                    }
                }

                stage('Secrets Scan') {
                    stages {
                        stage('Install TruffleHog') {
                            steps {
                                sh '''
                                    curl -sSfL https://raw.githubusercontent.com/trufflesecurity/trufflehog/main/scripts/install.sh | sh -s -- -b .
                                '''
                            }
                        }

                        stage('Scan for Secrets') {
                            steps {
                                catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                                    sh '''
                                        ./trufflehog git file://BAP --only-verified --fail --json > trufflehog-report.json || true
                                    '''
                                }
                                archiveArtifacts artifacts: 'trufflehog-report.json', fingerprint: true
                            }
                        }
                    }
                }

                stage('Grype Container Scan') {
                    stages {
                        stage('Install Grype') {
                            steps {
                                sh '''
                                    curl -sSfL https://raw.githubusercontent.com/anchore/grype/main/install.sh | sh -s -- -b .
                                '''
                            }
                        }

                        stage('Scan Container Image') {
                            steps {
                                catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                                    sh '''
                                        ./grype "${IMAGE_NAME}" --fail-on high -o table
                                    '''
                                }
                            }
                        }
                    }
                }
            }
        }

        stage('Run Container') {
            steps {
                sh '''
                    docker rm -f "${APP_CONTAINER_NAME}" || true
                    docker run -d --name "${APP_CONTAINER_NAME}" -p "${APP_PORT}:${APP_INTERNAL_PORT}" "${IMAGE_NAME}"
                    sleep 10
                    docker ps
                    docker logs "${APP_CONTAINER_NAME}" | tail -n 50
                '''
            }
        }

        stage('OWASP ZAP Scan') {
            steps {
                catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                    sh '''
                        mkdir -p zap-report
                        chmod 777 zap-report
                        docker run --rm \
                            --add-host=host.docker.internal:host-gateway \
                            -v "$PWD/zap-report:/zap/wrk:rw" \
                            ghcr.io/zaproxy/zaproxy:stable \
                            zap-baseline.py \
                            -t "http://host.docker.internal:${APP_PORT}" \
                            -r zap-report.html \
                            -J zap-report.json \
                            -d -I
                    '''
                }
                archiveArtifacts artifacts: 'zap-report/**', fingerprint: true
            }
        }

        stage('Archive Artifacts') {
            steps {
                archiveArtifacts artifacts: 'sbom.cdx.json,trufflehog-report.json,zap-report/**', fingerprint: true
            }
        }
    }

    post {
        always {
            sh '''
                docker rm -f "${APP_CONTAINER_NAME}" || true
                docker rmi "${IMAGE_NAME}" || true
                cleanWs
            '''
        }
    }
}